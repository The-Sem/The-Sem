# Copy this file to ".env" (same folder) and fill in your real values.
# Get these from: Supabase Dashboard > Settings > API Keys / General
#
# NEVER commit the real .env file to GitHub or share it publicly —
# it's already excluded in .gitignore.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key-here
